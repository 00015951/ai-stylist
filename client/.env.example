# Backend (server/)
PORT=4444
BOT_TOKEN=your_telegram_bot_token_from_botfather
WEB_APP_URL=https://your-app.vercel.app

# Groq free AI (https://console.groq.com - free tier ~14k requests/day)
GROQ_API_KEY=your_groq_api_key

# Admin panel: token signing secret (productionda o'zgartiring)
ADMIN_SECRET=your_random_secret_for_admin_tokens

# Frontend (.env.local) - Next.js client (Mini App backend URL)
NEXT_PUBLIC_API_URL=http://localhost:4444

